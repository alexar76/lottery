# AI-Agent Oracle Lottery — environment. Copy to .env and edit for LIVE/UNI.
# `docker compose up` already works in DEMO with no .env (keys are baked in compose).

# ── mode ──────────────────────────────────────────────────────────────────────
LOTTERY_MODE=demo                 # demo | live | uni

# ── chain ───────────────────────────────────────────────────────────────────
RPC_URL=http://chain:8545
CHAIN_ID=31337
# LOTTERY_ADDRESS=0x…             # or let the deploy step write LOTTERY_ADDRESS_FILE
LOTTERY_ADDRESS_FILE=/shared/lottery.address

# ── identities (LIVE: use real, DISTINCT, secured keys; see docs/AUDIT.md) ─────
OPERATOR_KEY=0x…                  # opens/closes/draws; also signer+treasury in demo
# ORACLE_SIGNER_KEY=0x…           # defaults to OPERATOR_KEY
# TREASURY_KEY=0x…                # defaults to OPERATOR_KEY
SPONSOR_KEY=0x…                   # the Hub's funding account (altruistic tithe)
BENEFACTOR_KEY=0x…                # the UNI external benefactor ($100/week)
AGENT_KEYS=0x…,0x…                # synthetic crowd the relayer drives (demo/uni)

# ── oracles (LIVE pays real services; DEMO uses local stand-ins) ──────────────
# Set HUB_URL to route + pay through the AIMarket Hub (1% routing fee), OR set
# ORACLE_URL to call the oracle-family directly. Leave both empty for demo.
# HUB_URL=https://hub.modelmarket.dev
# ORACLE_URL=https://oracles.modelmarket.dev
# PAYMENT_CHANNEL=chan_…          # X-Payment-Channel for paid Hub invokes
ONCHAIN_VDF=false                 # true → submit & verify a real Chronos VDF on-chain
# CHRONOS_CANONICAL_N=0x…         # required for ONCHAIN_VDF: hex modulus == ChronosVDF.CANONICAL_N
                                  # (Chronos must run with this modulus; else the relayer fails the round safe)

# ── Hub-OWNED charity (the donor decides generosity + which lottery) ──────────
# Set on the HUB (AIMARKET_CHARITY_*); the relayer reads HUB_* or AIMARKET_CHARITY_*.
# AIMARKET_CHARITY_ENABLED=1
# AIMARKET_CHARITY_TITHE_BPS=2000        # 20% of the Hub's routing-fee revenue
# AIMARKET_CHARITY_LOTTERY_ADDRESS=0x…   # the bound lottery (anti-redirect target)
# AIMARKET_CHARITY_INTERVAL_HOURS=24     # the Hub PUSHES the accrued tithe every N hours
# HUB_TITHE_BPS / HUB_CHARITY_ENABLED / HUB_LOTTERY_ADDRESS / HUB_TITHE_INTERVAL_HOURS also work (aliases)
# DEMO_TITHE_INTERVAL_S=15               # accelerated cadence so the schedule is visible in demo mode

# ── LOTTERY-owned economics (split is deployed on-chain; opex policy here) ────
# The split (PRIZE_BPS/OPEX_BPS of TOTAL income, prize floor 70%) is set at deploy.
TREASURER_ENABLED=1               # the autonomous AI Treasurer manages the opex bucket
TREASURER_MODE=policy             # policy (deterministic) | llm (asks an agent, falls back)
RESERVE_TARGET_USD=5              # solvency buffer the Treasurer holds back

# ── economy ─────────────────────────────────────────────────────────────────
WEI_PER_USD=1000000000000000      # $1 = 0.001 ETH (display + USD→wei; demo play-money)
HUB_ROUTING_REVENUE_USD=5         # simulated Hub routing-fee revenue/round → tithe source
UNI_WEEKLY_USD=100                # UNI external benefactor weekly allocation
SELL_WINDOW=4                     # real seconds external agents have to buy before close
ROUND_INTERVAL=5                  # pause between rounds

# ── observability ─────────────────────────────────────────────────────────────
SERVE_PORT=8090
# MONITOR_URL=http://localhost:8000   # POST live economy to the Alien Monitor
